# Copy to .env.local and fill in. All server-side; nothing here is public.

# Supabase project (Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=          # service_role key, full DB access behind the PIN

# sha256 of your login PIN. Generate with:
#   node -e "console.log(require('crypto').createHash('sha256').update('YOURPIN').digest('hex'))"
APP_PIN_HASH=

# Any long random string. Signs the session cookie.
SESSION_SECRET=

# IANA timezone for day boundaries (when "today" rolls over). Optional, defaults to UTC.
APP_TZ=UTC
