<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.cutcoach.garmin-sync</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Library/Frameworks/Python.framework/Versions/3.13/bin/python3</string>
    <string>/Users/joudbitar/cut-coach/scripts/garmin_sync.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/joudbitar/cut-coach</string>

  <!-- Run at 08:30 and 21:00 local time -->
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Hour</key><integer>8</integer><key>Minute</key><integer>30</integer></dict>
    <dict><key>Hour</key><integer>21</integer><key>Minute</key><integer>0</integer></dict>
  </array>

  <!-- Also run once shortly after the Mac wakes/loads the agent -->
  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/joudbitar/cut-coach/scripts/garmin_sync.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/joudbitar/cut-coach/scripts/garmin_sync.log</string>
</dict>
</plist>
